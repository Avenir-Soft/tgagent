# ── App ──────────────────────────────────────────────────────────────────────
DEBUG=true
SECRET_KEY=change-me-to-a-random-secret-key
ENCRYPTION_KEY=change-me-32-bytes-key-here!!!!

# ── Database ─────────────────────────────────────────────────────────────────
# Local:  postgresql+asyncpg://postgres:postgres@localhost:5432/ai_closer
# Docker: postgresql+asyncpg://postgres:postgres@db:5432/ai_closer
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_closer
DATABASE_ECHO=false

# Docker Compose Postgres settings (only used by docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ai_closer

# ── Redis ────────────────────────────────────────────────────────────────────
# Local:  redis://localhost:6379/0
# Docker: redis://redis:6379/0
REDIS_URL=redis://localhost:6379/0

# ── JWT ──────────────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Telegram (get from https://my.telegram.org) ─────────────────────────────
TELEGRAM_API_ID=0
TELEGRAM_API_HASH=
TELEGRAM_SESSIONS_DIR=./sessions

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL_MAIN=gpt-4o-mini
OPENAI_MODEL_FALLBACK=gpt-4o

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_FORMAT=text
LOG_LEVEL=INFO

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Frontend (for docker-compose) ───────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
