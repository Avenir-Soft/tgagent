# App
DEBUG=true
SECRET_KEY=change-me-to-a-random-secret-key

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_closer
DATABASE_ECHO=false

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Telegram (get from https://my.telegram.org)
TELEGRAM_API_ID=0
TELEGRAM_API_HASH=
TELEGRAM_SESSIONS_DIR=./sessions

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL_FAST=gpt-4o-mini
OPENAI_MODEL_STRONG=gpt-4o

# Encryption key for Telegram session data (32 bytes)
ENCRYPTION_KEY=change-me-32-bytes-key-here!!!!
